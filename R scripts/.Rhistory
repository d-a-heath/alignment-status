#load packages
library("tidyverse")
library("readxl")
library("spacyr")
library("crqa")
library("here")
#clear workspace
rm(list=ls())
#specify our dirs
here()
csv_dir <- "C:/Users/daheath/OneDrive - The University of Memphis/Alignment Status/CANDOR/test set/test transcripts"
survey_dir <- "C:/Users/daheath/OneDrive - The University of Memphis/Alignment Status/CANDOR/test set/test surveys"
save_dir <- "C:/Users/daheath/OneDrive - The University of Memphis/Alignment Status/CANDOR/test set"
#C:/Users/daheath/OneDrive - The University of Memphis/Alignment Status/CANDOR/test set/test surveys
#create lists of our transcripts and surveys
transcripts <- list.files(path = csv_dir,
pattern = "transcript_cliffhanger.csv",
full.names = FALSE,
recursive = FALSE,
include.dirs = TRUE)
surveys <- list.files(path = survey_dir,
pattern = "survey.csv",
full.names = FALSE,
recursive = FALSE,
include.dirs = TRUE)
#create empty dataframe to write difference scores into
survey_output_df <- data.frame()
#loop through each survey and calculate difference scores, write into dataframe created above
#political "sameness" allows for one-degree of difference, age "sameness" is within 5 years
for(file in surveys){
survey_data <- read.csv(file)
reported_status_1 <- survey_data$i_think_my_status[1]
reported_status_2 <- survey_data$i_think_my_status[2]
reported_status_diff <- abs(reported_status_1 - reported_status_2)
perceived_status_1 <- survey_data$i_think_your_status[1]
perceived_status_2 <- survey_data$i_think_your_status[2]
perceived_status_diff <- abs(perceived_status_1 - perceived_status_2)
sex_1 <- survey_data$sex[1]
sex_2 <- survey_data$sex[2]
sex_diff <- ifelse(sex_1 == sex_2,0,1)
race_1 <- survey_data$race[1]
race_2 <- survey_data$race[2]
race_diff <- ifelse(race_1 == race_2,0,1)
politics_1 <- survey_data$politics[1]
politics_2 <- survey_data$politics[2]
politics_diff <- ifelse(abs(politics_1 == politics_2)<=1, 0,1)
edu_1 <- survey_data$edu[1]
edu_2 <- survey_data$edu[2]
edu_diff <- ifelse(edu_1 == edu_2, 0,1)
age_1 <- survey_data$age[1]
age_2 <- survey_data$age[2]
age_diff <- ifelse(abs(age_1 - age_2) <= 5,0,1)
total_diff <- sex_diff+race_diff+politics_diff+edu_diff+age_diff
survey_output_df<- rbind(survey_output_df,
cbind(survey_data$convo_id[1],
reported_status_diff,
perceived_status_diff,
sex_diff,
race_diff,
politics_diff,
edu_diff,
age_diff,
total_diff))
}
getwd()
